{
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.+\\.(?:png|jpg|jpeg|gif|svg|ico|webp))$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/(.+\\.(?:css|woff2?|ttf|eot))$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/today", "destination": "/today-pick.html" },
    { "source": "/message", "destination": "/message.html" },
    { "source": "/calc", "destination": "/calc.html" },
    { "source": "/vote", "destination": "/vote.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/ops", "destination": "/ops.html" }
  ],
  "redirects": [
    { "source": "/dist/:path*", "destination": "/404.html", "statusCode": 404 }
  ]
}
